<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springboot.mapper.VolumeMapper">

    <select id="selectByWorkId" resultType="com.example.springboot.entity.Volume">
        SELECT * FROM volumes
        WHERE work_id = #{workId}
        ORDER BY sort
    </select>

    <insert id="insert" parameterType="com.example.springboot.entity.Volume" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO volumes (work_id, title, sort, created_at)
        VALUES (#{workId}, #{title}, #{sort}, NOW())
    </insert>

    <delete id="delete" parameterType="int">
        DELETE FROM volumes WHERE id = #{id}
    </delete>
</mapper>
